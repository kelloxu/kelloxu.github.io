    <title>搭建hadoop集群</title>
    <link href="http://yoursite.com/2020/05/10/%E5%A4%A7%E6%95%B0%E6%8D%AE%E5%BC%80%E5%8F%91/"/>
    <id>http://yoursite.com/2020/05/10/%E5%A4%A7%E6%95%B0%E6%8D%AE%E5%BC%80%E5%8F%91/</id>
    <published>2020-05-10T14:12:57.000Z</published>
    <updated>2020-05-17T14:38:40.295Z</updated>
    
