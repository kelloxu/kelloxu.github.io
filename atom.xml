  <entry>
    <title>Java多线程系列(2)——线程的创建和启动</title>
    <link href="http://yoursite.com/2020/05/24/Java%E5%A4%9A%E7%BA%BF%E7%A8%8B%E7%B3%BB%E5%88%97-2-%E2%80%94%E2%80%94%E7%BA%BF%E7%A8%8B%E7%9A%84%E5%88%9B%E5%BB%BA%E5%92%8C%E5%90%AF%E5%8A%A8/"/>
    <id>http://yoursite.com/2020/05/24/Java%E5%A4%9A%E7%BA%BF%E7%A8%8B%E7%B3%BB%E5%88%97-2-%E2%80%94%E2%80%94%E7%BA%BF%E7%A8%8B%E7%9A%84%E5%88%9B%E5%BB%BA%E5%92%8C%E5%90%AF%E5%8A%A8/</id>
